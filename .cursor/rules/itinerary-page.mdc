## 4. AEO Block (obligatoire)

```tsx
import { buildAeoBlock } from '@mch/seo';

// Valider AVANT le render — throw si invalide (fail fast)
const aeoResult = buildAeoBlock({
  question:  locale === 'fr' ? itinerary.aeo_question_fr : itinerary.aeo_question_en,
  answer:    locale === 'fr' ? itinerary.aeo_answer_fr   : itinerary.aeo_answer_en,
  sourceUrl: canonicalUrl,
  updatedAt: itinerary.last_updated,
});
if (!aeoResult.ok) {
  throw new Error(`AEO validation failed: ${JSON.stringify(aeoResult.error)}`);
}
```

```tsx
<section data-aeo aria-labelledby="aeo-heading">
  <h2 id="aeo-heading" className="sr-only">{aeoResult.value.question}</h2>
  <p>{aeoResult.value.answer}</p>
  <LastUpdatedBadge date={aeoResult.value.updatedAt} />
</section>
```

