## 2. `generateMetadata` (obligatoire)

```ts
export async function generateMetadata({
  params,
}: {
  params: Promise<{ locale: string; slug: string }>;
}) {
  const { locale, slug } = await params;
  const itinerary = await getItineraryBySlug(slug, locale);
  if (!itinerary) return { robots: { index: false, follow: false } };

  const canonical = `/${locale}/${
    locale === 'fr' ? 'itineraire' : 'itinerary'
  }/${slug}`;

  return {
    title:       locale === 'fr' ? itinerary.meta_title_fr : itinerary.meta_title_en,
    description: locale === 'fr' ? itinerary.meta_desc_fr  : itinerary.meta_desc_en,
    alternates: {
      canonical,
      languages: {
        'fr-FR':    `/fr/itineraire/${itinerary.slug_fr}`,
        'en':       `/en/itinerary/${itinerary.slug_en ?? itinerary.slug_fr}`,
        'x-default': `/fr/itineraire/${itinerary.slug_fr}`,
      },
    },
    openGraph: {
      images: itinerary.hero_cloudinary_id
        ? [{ url: cloudinaryUrl(itinerary.hero_cloudinary_id, 1200, 630) }]
        : [],
    },
  };
}
```

