{
  "$schema": "MyConciergeHotel Design Tokens v1.0",
  "description": "Tokens extraits du code de production. Réutilisables en Tailwind theme.extend, Style Dictionary ou CSS variables.",
  "color": {
    "neutral": {
      "noir": {
        "value": "#3A352D",
        "usage": "Titres, boutons pleins (taupe très foncé, jamais de noir profond)"
      },
      "anthracite": { "value": "#4A4439", "usage": "Hover bouton, citations" },
      "texte": { "value": "#2B2722", "usage": "Texte courant" },
      "texteDoux": { "value": "#6F675B", "usage": "Texte secondaire, légendes" }
    },
    "accent": {
      "or": {
        "value": "#8C7B5A",
        "usage": "Accent principal — eyebrow, liens, étoiles (taupe sobre, JAMAIS d'or jaune)"
      },
      "orClair": { "value": "#A89671", "usage": "Accent clair sur fond sombre / photo" }
    },
    "surface": {
      "creme": { "value": "#F6F1E7", "usage": "Fond principal (JAMAIS de fond sombre)" },
      "creme2": { "value": "#EFE8DA", "usage": "Section alternée" },
      "creme3": { "value": "#E8E0D0", "usage": "Footer, bandeaux" },
      "blanc": { "value": "#FFFFFF", "usage": "Cartes" }
    },
    "line": { "value": "rgba(140,123,90,0.28)", "usage": "Filets, bordures cartes" }
  },
  "shadow": {
    "soft": { "value": "0 10px 30px rgba(22,20,15,0.10)" },
    "base": { "value": "0 18px 50px rgba(22,20,15,0.18)" }
  },
  "font": {
    "family": {
      "serif": {
        "value": "'EB Garamond','Cormorant Garamond',Georgia,serif",
        "usage": "Titres, citations, prix"
      },
      "sans": { "value": "'Outfit','Jost',system-ui,sans-serif", "usage": "UI, corps, eyebrow" }
    },
    "weight": { "light": 300, "regular": 400, "medium": 500 },
    "size": {
      "h1": { "value": "clamp(46px,6.6vw,92px)" },
      "h1Interne": { "value": "clamp(34px,5vw,58px)", "usage": "H1 pages classement/guide" },
      "h2": { "value": "clamp(30px,4vw,46px)" },
      "h3": { "value": "22px" },
      "bodyLg": { "value": "17px" },
      "body": { "value": "16px" },
      "caption": { "value": "13px" },
      "eyebrow": { "value": "12px" }
    },
    "lineHeight": { "titre": 1.08, "corps": 1.6 },
    "letterSpacing": { "eyebrow": "0.34em", "nav": "0.12em", "btn": "0.13em" }
  },
  "layout": {
    "wrap": { "value": "min(1240px,92vw)" },
    "sectionPad": { "value": "90px" },
    "sectionPadMobile": { "value": "64px" }
  },
  "radius": {
    "card": { "value": "8px" },
    "cardLg": { "value": "14px" },
    "pill": { "value": "999px" },
    "btn": { "value": "2px" }
  },
  "transition": {
    "image": { "value": "transform .7s cubic-bezier(.2,.7,.2,1)", "usage": "Zoom photo au hover" },
    "ui": { "value": ".28s ease" }
  },
  "breakpoints": {
    "desktop": "1000px+",
    "tablet": "max-width:1000px",
    "mobile": "max-width:640px"
  }
}
